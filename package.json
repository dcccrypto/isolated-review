{
  "name": "isolated-review",
  "version": "0.10.0",
  "description": "Deep code review of a single file in isolation",
  "license": "Apache-2.0",
  "author": "Khubair Nasir",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dcccrypto/isolated-review.git"
  },
  "bugs": {
    "url": "https://github.com/dcccrypto/isolated-review/issues"
  },
  "homepage": "https://github.com/dcccrypto/isolated-review#readme",
  "keywords": [
    "cli",
    "code-review",
    "ai",
    "claude",
    "openai",
    "anthropic"
  ],
  "type": "module",
  "bin": {
    "review": "dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@inquirer/prompts": "^8.4.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "openai": "^4.70.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
